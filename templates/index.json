    "faq": {
      "type": "faq",
      "blocks": {
        "166442457738b23caf-0": {
          "type": "item",
          "settings": {
            "title": "Est-ce que ça fait mal ?",
            "content": "<p>Non. Les lames protégées ne touchent pas directement la peau. Zéro douleur, zéro brûlure même sur les zones les plus sensibles. Tu peux l'utiliser tous les jours sans aucune irritation.</p>"
          }
        },
        "166442457738b23caf-1": {
          "type": "item",
          "settings": {
            "title": "Ça fonctionne sur quelles zones ?",
            "content": "<p>Partout. Jambes, aisselles, bras, zones sensibles et visage. Un seul appareil remplace tous tes outils d'épilation habituels. Conçu aussi bien pour les femmes que pour les hommes.</p>"
          }
        },
        "166442457738b23caf-2": {
          "type": "item",
          "settings": {
            "title": "Je peux l'utiliser sous la douche ?",
            "content": "<p>Oui, Veloria est 100% waterproof. Utilise-le sec ou sous l'eau, en toute sécurité. La recharge USB-C prend moins de 2h pour jusqu'à 45 minutes d'autonomie.</p>"
          }
        },
        "item_BqJP66": {
          "type": "item",
          "settings": {
            "title": "C'est vraiment différent d'un rasoir classique ?",
            "content": "<p>Complètement. Un rasoir classique coupe au ras de la peau et provoque irritations et poils incarnés. Veloria protège la peau à chaque passage, résultat plus doux, qui dure plus longtemps.</p>"
          }
        },
        "item_HLmQUV": {
          "type": "item",
          "settings": {
            "title": "La livraison prend combien de temps ?",
            "content": "<p>Entre 5 et 10 jours ouvrés en France. Un numéro de suivi t'est envoyé par email dès l'expédition de ta commande.</p>"
          }
        }
      },
